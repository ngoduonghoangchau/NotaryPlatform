# ── docker-compose environment template ──────────────────────────────────────
# Copy to your env file (git-ignored) and fill in REAL values. NEVER commit it.
# No quotes around values. Generate the JWT key with:  openssl rand -hex 32
#
# WHERE this file goes — Compose reads ${VAR} interpolation from a root `.env` OR from
# `--env-file <path>` (NOT from a service `env_file:`). Two options:
#   A) root `.env`:                 cp .env.example .env       →  docker compose up -d --build
#   B) reuse your app env file:     add the vars below to backend/NotaryPlatform.API/.env
#                                   →  docker compose --env-file backend/NotaryPlatform.API/.env up -d --build
#
# REQUIRED for interpolation: POSTGRES_PASSWORD, REDIS_PASSWORD, SITE_ADDRESS, PUBLIC_BASE_URL.

# Public address Caddy serves on:
#   • a real domain → real Let's Encrypt certificate   (e.g. SITE_ADDRESS=notary.example.com)
#   • ":443"        → self-signed internal certificate (testing only)
SITE_ADDRESS=:443
# Your public HTTPS base URL — used to build file download links (set to your real domain):
PUBLIC_BASE_URL=https://localhost

# ── Datastore passwords (compose interpolates these; keep them strong) ──
POSTGRES_PASSWORD=change-me-strong-db-password
REDIS_PASSWORD=change-me-strong-redis-password

# ── JWT (required) ──
Jwt__SecretKey=change-me-run-openssl-rand-hex-32
Jwt__Issuer=NotaryPlatform
Jwt__Audience=NotaryPlatform

# ── File storage: choose ONE provider ──
#   local      → files on the box's disk (default, simplest)
#   cloudinary → free-tier object storage + CDN, files kept OFF the box (durable; see below)
#   cloud      → Google Cloud Storage (needs a Firebase service account)
Storage__Provider=local

# Cloudinary — used ONLY when Storage__Provider=cloudinary (free tier ~25 GB).
# Copy these from your Cloudinary dashboard. Api secret is a secret — keep it here, never commit.
# Files are uploaded PRIVATE and served via short-lived signed URLs.
# Cloudinary__CloudName=your-cloud-name
# Cloudinary__ApiKey=your-api-key
# Cloudinary__ApiSecret=your-api-secret

# ── SMS: disabled at $0 (a no-op sender is used) ──
Sms__Disabled=true

# ── Email: a free SMTP provider (Brevo / Gmail / Resend) ──
Smtp__Host=smtp-relay.brevo.com
Smtp__Port=587
Smtp__UserName=your-smtp-username
Smtp__Password=your-smtp-password
Smtp__SenderEmail=noreply@your-domain
Smtp__SenderName=NotaryPlatform
Smtp__UseSsl=false

# ── Firebase (OPTIONAL): Firestore read model + FCM push, free Spark plan ──
# If used: put the service-account JSON at ./secrets/firebase.json and uncomment the
# firebase lines in docker-compose.yml.
Firestore__ProjectId=

# ── Observability: off at $0 (console/file logs). Set an OTLP URL to enable later. ──
Telemetry__OtlpEndpoint=

# ── First-boot data seeding: DEV/DEMO ONLY. Leave false in real production. ──
# Seeding__RunOnStartup=false
